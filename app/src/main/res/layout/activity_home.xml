<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_home.xml
    ==================
    Main screen layout.
    - Header bar with welcome, My Orders, Logout buttons
    - Area Spinner (dropdown)
    - RecyclerView for tailor list
    - Empty state TextView
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ===== TOP HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E91E63"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="6dp">

        <!-- Left: App name + welcome -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✂️ Silai"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello 👋"
                android:textColor="#FFCDD2"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- My Orders Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMyOrders"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="My Orders"
            android:textSize="11sp"
            android:textStyle="bold"
            app:backgroundTint="#C2185B"
            app:cornerRadius="18dp"
            android:layout_marginEnd="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Logout"
            android:textSize="11sp"
            app:backgroundTint="#880E4F"
            app:cornerRadius="18dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"/>

    </LinearLayout>

    <!-- ===== AREA SELECTOR CARD ===== -->
    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Select Your Area"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinnerArea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/spinner_bg"
                android:padding="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== TAILOR COUNT TEXT ===== -->
    <TextView
        android:id="@+id/tvTailorCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:text="Loading tailors..."
        android:textColor="#757575"
        android:textSize="13sp"/>

    <!-- ===== TAILOR LIST (RecyclerView) ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTailors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/tvNoTailors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😕"
            android:textSize="48sp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No tailors found in this area"
            android:textColor="#757575"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</LinearLayout>