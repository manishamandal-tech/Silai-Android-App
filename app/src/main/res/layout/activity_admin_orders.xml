<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#212121">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FF5722" android:padding="16dp"
        android:orientation="horizontal" android:gravity="center_vertical">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
            android:layout_height="36dp" android:text="← Back"
            android:backgroundTint="#E64A19" android:textColor="#FFFFFF" android:textSize="12sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="📋 All Orders"
            android:textColor="#FFFFFF" android:textSize="18sp"
            android:textStyle="bold" android:gravity="center"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvOrderCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Total Orders: 0"
        android:textColor="#9E9E9E"
        android:textSize="13sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvNoOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="No orders yet"
        android:gravity="center"
        android:textColor="#616161"
        android:textSize="16sp"
        android:visibility="gone"/>

</LinearLayout>