<?xml version="1.0" encoding="utf-8"?>
<!--
    item_order.xml
    ===============
    Layout for a single order in the tracking RecyclerView.
    Shows: order ID, tailor, cloth, date, status (color coded),
           4-step progress tracker with emoji.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Order ID + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order #1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pickup Scheduled"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#FFF9C4"
                android:padding="6dp"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F5F5F5" android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Row 2: Tailor Name -->
        <TextView
            android:id="@+id/tvTailorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧵 Tailor Name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#424242"/>

        <!-- Row 3: Cloth Type -->
        <TextView
            android:id="@+id/tvClothType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👗 Kurta"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="3dp"/>

        <!-- Row 4: Date/Time -->
        <TextView
            android:id="@+id/tvOrderDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 12/04/2025"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="3dp"/>

        <!-- Row 5: Instructions -->
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Instructions"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginTop="3dp"
            android:visibility="gone"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#F5F5F5" android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"/>

        <!-- Progress Steps Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Step 1 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView
                    android:id="@+id/step1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📦" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Pickup" android:textSize="9sp" android:textColor="#757575"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Connector -->
            <View android:layout_width="0dp" android:layout_height="2dp"
                android:layout_weight="0.3" android:background="#E91E63"/>

            <!-- Step 2 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView
                    android:id="@+id/step2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✂️" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Stitching" android:textSize="9sp" android:textColor="#757575"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Connector -->
            <View android:layout_width="0dp" android:layout_height="2dp"
                android:layout_weight="0.3" android:background="#E91E63"/>

            <!-- Step 3 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView
                    android:id="@+id/step3"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🚚" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Delivery" android:textSize="9sp" android:textColor="#757575"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Connector -->
            <View android:layout_width="0dp" android:layout_height="2dp"
                android:layout_weight="0.3" android:background="#E91E63"/>

            <!-- Step 4 -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView
                    android:id="@+id/step4"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✅" android:textSize="20sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Delivered" android:textSize="9sp" android:textColor="#757575"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>