<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#7B1FA2"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="← Back" android:backgroundTint="#6A1B9A"
            android:textColor="#FFFFFF" android:textSize="12sp"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="📷 Upload Design Image"
            android:textColor="#FFFFFF" android:textSize="18sp"
            android:textStyle="bold" android:gravity="center"/>
    </LinearLayout>

    <!-- Image Preview -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp">

        <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#F3E5F5"
                android:src="@drawable/ic_tailor_placeholder"/>

            <!-- Placeholder text when no image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👗" android:textSize="52sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tap below to add your cloth image"
                    android:textColor="#CE93D8" android:textSize="14sp" android:layout_marginTop="8dp"/>
            </LinearLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvImageStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="No image selected"
        android:textColor="#9E9E9E"
        android:textSize="13sp"
        android:layout_marginBottom="16dp"/>

    <!-- Choose Image Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnChooseImage"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:text="📷  Choose Image (Camera / Gallery)"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="#7B1FA2"
        app:cornerRadius="10dp"/>

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveImage"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:text="✅  Save Image"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="#4CAF50"
        app:cornerRadius="10dp"/>

    <!-- Info text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️ Upload a reference image of your cloth or design style to help the tailor understand your requirements better."
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:padding="16dp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>